    "dns": {
        "servers": [
            {
                "tag": "google",
                "type": "tls",
                "server": "8.8.8.8",
                "tls": {
                    "enabled": true,
                    "server_name": "dns.google"
                },
                "detour": "Proxy"
            },
            {
                "tag": "ali",
                "type": "udp",
                "server": "223.5.5.5"
            },
            {
                "tag": "me",
                "type": "local"
            }
        ],
        "rules": [
            {
                "domain_suffix": [
                    ".lan"
                ],
                "server": "me"
            },
            {
                "rule_set": [
                    "blocklist"
                ],
                "action": "predefined",
                "rcode": "NXDOMAIN",
                "answer": [
                    "adobe.io.  IN A  66.33.88.0",
                    "adobe.com. IN A  67.33.88.0",
                    "adobelogin.com. IN A  122.55.77.88",
                    "cloudflare.net. IN A  122.55.77.80"
                ]
            },
            {
                "rule_set": [
                    "category-ads-all"
                ],
                "action": "reject"
            },
            {
                "clash_mode": "global",
                "server": "google",
                "disable_cache": true
            },
            {
                "clash_mode": "direct",
                "server": "ali"
            },
            {
                "type": "logical",
                "mode": "or",
                "rules": [
                    {
                        "rule_set": [
                            "geosite-geolocation-cn",
                            "geosite-cn"
                        ]
                    }
                ],
                "server": "ali"
            },
            {
                "type": "logical",
                "mode": "and",
                "rules": [
                    {
                        "rule_set": "geosite-geolocation-!cn",
                        "invert": true
                    },
                    {
                        "rule_set": "geoip-cn"
                    }
                ],
                "server": "google",
                "disable_cache": true,
                "client_subnet": "114.114.114.114/24" // Any China client IP address
            }
        ],
        "strategy": "ipv4_only",
        // "strategy": "prefer_ipv6",
        "disable_cache": true,
        "final": "google"
    },
