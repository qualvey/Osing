                        "ip_is_private": true
                    }
                ],
                "outbound": "direct"
            },
            //下面这个规则是否使用，还不好说，我也不太明白
            // {
            //     "type": "logical",
            //     "mode": "or",
            //     "rules": [
            //你的设备将无法通过 853 端口进行加密查询。如果你的 DNS 设置里用了 tls:// 地址，可能会导致无法上网。
            //         {
            //             "port": 853
            //         },
            //主要是拦截 YouTube、Chrome 访问 Google 服务时使用的 QUIC 协议。拦截后流量会降级回普通的 TCP (HTTPS)，通常用于解决部分线路 UDP 容易被运营商限速的问题。
            //         {
            //             "network": "udp",
            //             "port": 443
            //         },
            //拦截 P2P 探测。这会导致 WebRTC（网页通话）、某些在线游戏、P2P 下载（BT）难以建立直接连接，可能导致视频通话黑屏或下载速度慢。
            //         {
            //             "protocol": "stun"
            //         }
            //     ],
            //     "action": "reject"
            // },
            {
                "type": "logical",
                "mode": "and",
                "rules": [
                    {
                        "rule_set": "geoip-cn"
                    },
                    {
                        "rule_set": "geosite-geolocation-!cn",
                        "invert": true
                    }
                ],
                "outbound": "direct"
            }
        ],
        "rule_set": [
